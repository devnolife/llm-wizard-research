# Backend-specific environment overrides (optional)
# Precedence: root ../.env is loaded first as the main configuration;
# backend/.env is loaded second with override=True for backend-only overrides.
# Keep real secrets out of this example; copy keys to ../.env or .env as needed.

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=1

# LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_MAX_TOKENS=2000
LLM_CONTEXT_WINDOW=8192
LLM_TIMEOUT=120
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PARALLEL=4

# Vector Database
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=research_papers_ml
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# External API Keys (optional; leave empty in examples)
SEMANTIC_SCHOLAR_API_KEY=
PUBMED_API_KEY=
PUBMED_EMAIL=
CROSSREF_EMAIL=
CORE_API_KEY=
ELSEVIER_API_KEY=
ELSEVIER_INSTTOKEN=
IEEE_API_KEY=
SPRINGER_API_KEY=

# Data Paths
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed

# Retrieval Configuration
RETRIEVAL_TOP_K=5
MIN_RELEVANCE_SCORE=0.15
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RERANK_ENABLED=true
CHUNK_STRATEGY=sections

# OCR Configuration
OCR_ENABLED=false
OCR_SERVICE_URL=http://127.0.0.1:10000
OCR_IMAGE_MODE=gundam
OCR_DPI=200
OCR_CONCURRENCY=4
OCR_TIMEOUT=1200
OCR_MIN_CHARS_PER_PAGE=50
OCR_NGRAM_SIZE=35
OCR_NGRAM_WINDOW=128
OCR_VALIDATE_ON_STARTUP=false

# Durable local analysis queue and metadata-only telemetry
ANALYSIS_QUEUE_WORKERS=2
ANALYSIS_JOB_MAX_ATTEMPTS=2
ANALYSIS_JOB_RETENTION_DAYS=30
TELEMETRY_ENABLED=true
TELEMETRY_RETENTION_DAYS=14

# Neo4j (Optional - for knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
