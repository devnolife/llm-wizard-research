# Environment Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# LLM Configuration
LLM_MODEL_NAME=glm-4-flash
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Vector Database
VECTOR_DB_PERSIST_DIR=./chroma_db
VECTOR_DB_COLLECTION=research_papers_ml
VECTOR_DB_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# External API Keys (Optional but recommended)
SEMANTIC_SCHOLAR_API_KEY=
PUBMED_API_KEY=
PUBMED_EMAIL=
CROSSREF_EMAIL=
CORE_API_KEY=

# Elsevier ScienceDirect (get a free key at https://dev.elsevier.com/)
# ELSEVIER_INSTTOKEN is optional: needed for full-text of subscribed content
# when off-campus. On the UNHAS network/VPN the API key alone may suffice.
ELSEVIER_API_KEY=
ELSEVIER_INSTTOKEN=

# Data Paths
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed

# Retrieval Configuration
RETRIEVAL_TOP_K=10
RETRIEVAL_MIN_RELEVANCE_SCORE=0.5
RETRIEVAL_CHUNK_SIZE=512
RETRIEVAL_CHUNK_OVERLAP=50

# Neo4j (Optional - for knowledge graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
